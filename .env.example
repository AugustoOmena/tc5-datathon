# Copie este arquivo para .env e use credenciais reais apenas localmente.
# Nunca versione o arquivo .env com segredos.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=adm*****23

# Para predição funcionar localmente, informe credenciais AWS com acesso ao bucket do modelo.
AWS_ACCESS_KEY_ID=AKIA****************
AWS_SECRET_ACCESS_KEY=********************************
AWS_DEFAULT_REGION=sa-east-1
# AWS_SESSION_TOKEN=********************************

# Defina false para exigir artefatos no startup (recomendado para predict funcionar).
# Defina true apenas para modo observabilidade, quando quiser subir API sem modelo.
ALLOW_STARTUP_WITHOUT_ARTIFACTS=false

# Bucket usado pela API no startup para buscar o modelo.
S3_BUCKET_NAME=tc5-mlops-artifacts-f4d7a3e1
